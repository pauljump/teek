{
  "name": "teek",
  "version": "1.0.0",
  "description": "Persona simulation engine — structured cognitive profiles for LLM simulation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "teek": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "persona",
    "simulation",
    "llm",
    "cognitive-profile",
    "ai",
    "agent",
    "character"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pauljump/teek.git"
  },
  "homepage": "https://github.com/pauljump/teek",
  "license": "MIT",
  "author": "Paul Jump",
  "dependencies": {
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
